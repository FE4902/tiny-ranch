{
  "name": "tiny-ranch",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:rollback": "VITE_EXPERIMENT_PHASER_BUILD=package npm run build",
    "bundle:measure": "npm run build && node scripts/measure-bundle.mjs",
    "bundle:measure:rollback": "VITE_EXPERIMENT_PHASER_BUILD=package npm run bundle:measure",
    "balance:check": "node scripts/check-expansion-pacing.mjs",
    "balance:check:return-objectives": "node scripts/check-return-objective-balance.mjs",
    "test:soak:retention": "node scripts/check-retention-soak.mjs",
    "test:soak:retention:memory": "playwright test --project=mobile-chromium tests/smoke/retention-memory-gate.spec.ts",
    "report:retention:health": "node scripts/report-retention-health.mjs",
    "gate:retention:baseline-diff": "node scripts/diff-retention-gate-baseline.mjs",
    "gate:retention:release": "node scripts/run-retention-release-gate.mjs",
    "gate:retention:replay": "node scripts/replay-retention-gate-stage.mjs",
    "gate:barn:mvp": "node scripts/run-barn-mvp-release-gate.mjs",
    "gate:mvp:release": "node scripts/run-mvp-release-candidate-gate.mjs",
    "release:handoff": "node scripts/run-mvp-launch-handoff.mjs",
    "test:retention:tuning-packs": "node scripts/test-retention-tuning-pack-loader.mjs",
    "test:telemetry:retention": "node scripts/validate-retention-telemetry-contract.mjs",
    "analytics:retention:cohort": "node scripts/export-retention-cohorts.mjs",
    "test:analytics:retention-cohort": "node scripts/test-retention-cohort-export.mjs",
    "test:analytics:retention": "npm run test:retention:tuning-packs && npm run test:telemetry:retention && npm run test:analytics:retention-cohort",
    "preview": "vite preview",
    "test:smoke": "playwright test",
    "test:smoke:launch-shell": "playwright test tests/smoke/launch-shell.spec.ts",
    "test:smoke:save-migration": "playwright test --project=desktop-chromium tests/smoke/save-migration-matrix.spec.ts",
    "test:smoke:headed": "playwright test --headed",
    "test:smoke:debug": "playwright test --debug"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.1"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  }
}
